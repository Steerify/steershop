# Environment Variables – SteerSolo WhatsApp Bot
# Copy this file to .env and fill in the values

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── WhatsApp Group ──────────────────────────────────────────────────────────
# The GROUP JID for the target WhatsApp group.
# To find it: once the bot is connected, join the group and check the bot logs.
# Format: 1234567890-1234567890@g.us
WHATSAPP_GROUP_JID=YOUR_GROUP_JID@g.us

# ─── Bot settings ────────────────────────────────────────────────────────────
# Posting interval in hours (default: 2)
POST_INTERVAL_HOURS=2

# ─── SteerSolo ───────────────────────────────────────────────────────────────
STEERSOLO_BASE_URL=https://steersolo.com

# ─── Group Invite ─────────────────────────────────────────────────────────────
# The WhatsApp group invite link shared in the "Join Us" post.
# Find it in the WhatsApp group → More options → Invite via link.
# Format: https://chat.whatsapp.com/XXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_GROUP_INVITE_LINK=https://chat.whatsapp.com/your-invite-code
